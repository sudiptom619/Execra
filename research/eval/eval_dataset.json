    "id": 50,
    "language": "python",
    "category": "logic",
    "difficulty": "hard",
    "code": "def flatten(lst, result=[]):\n    for item in lst:\n        if isinstance(item, list):\n            flatten(item, result)\n        else:\n            result.append(item)\n    return result",
    "expected_guidance": "Mutable default argument bug: 'result=[]' persists across calls, accumulating state",
    "ground_truth_fix": "def flatten(lst, result=None):\n    if result is None:\n        result = []\n    for item in lst:\n        if isinstance(item, list):\n            flatten(item, result)\n        else:\n            result.append(item)\n    return result",
    "should_trigger_guidance": true
