# Execra Configuration Example
# Copy this to .env and fill in your actual values

# LLM Configuration
LLM_BACKEND=gpt-4o
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# Screen Capture & Detection
SCREEN_CAPTURE_FPS=2
DETECTION_THRESHOLD=0.5
DELTA_THRESHOLD=0.05

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Trust Score Weights (must sum to approximately 1.0)
TRUST_SCORE_W1=0.5
TRUST_SCORE_W2=0.3
TRUST_SCORE_W3=0.2
